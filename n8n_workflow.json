        "text": "={{ (() => { const results = $json.results || []; const isEq = results.some(r => r.type === 'equivalence créée'); const isRec = results.some(r => r.type === 'recette créée'); let headerEmoji = '✅'; let headerText = 'Succès ! Les aliments ont été loggés dans ton journal Yazio.'; if (isEq) { headerEmoji = '✏️'; headerText = 'Nouvelle équivalence enregistrée !'; } else if (isRec) { headerEmoji = '🍳'; headerText = 'Recette bien enregistrée !'; } const detail = results.map(r => { if (r.status !== 'logged') return `❌ ${r.aliment} -> Non trouvé`; return `${r.aliment} -> ${r.yazio_name}`; }).join('\\n'); return `${headerEmoji} ${headerText}\\n\\nRésultat détaillé :\\n${detail}`; })() }}",
        "additionalFields": {
          "appendAttribution": false
