    {
      "parameters": {
        "jsCode": "let data;\nlet chat_id;\nconst triggerData = $(\"Telegram Trigger\").item.json;\n\n// 1. Récupération du Chat ID (qu'il vienne d'un message ou d'un clic)\nif (triggerData.message) {\n  chat_id = triggerData.message.chat.id;\n} else if (triggerData.callback_query) {\n  chat_id = triggerData.callback_query.message.chat.id;\n}\n\n// 2. Récupération de l'analyse (selon le chemin emprunté)\nif ($(\"Analyse Correction\").isExecuted) {\n  data = $(\"Analyse Correction\").item.json;\n} else if ($(\"Analyse Photo\").isExecuted) {\n  data = $(\"Analyse Photo\").item.json;\n} else if ($(\"Analyse Texte\").isExecuted) {\n  data = $(\"Analyse Texte\").item.json;\n}\n\n// 3. On ajoute le Chat ID à nos données et on envoie le tout !\ndata.chat_id = chat_id;\n\nreturn { json: data };"
      },
